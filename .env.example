# Telegram Bot Token — 从 @BotFather 创建机器人后获取
# 形如: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_TOKEN=

# Telegram MTProto API ID — 数字
# 在 https://my.telegram.org/apps 创建应用后获取
TELEGRAM_API_ID=

# Telegram MTProto API Hash — 字符串
# 与 API ID 配套，同样在 https://my.telegram.org/apps 获取
TELEGRAM_API_HASH=
